# ===== 复制本文件为 .env 后再修改实际值，切勿提交 .env 至仓库 =====
# 用法：cd docker && cp .env.example .env && docker compose up -d

# ===================== MySQL =====================
MYSQL_PORT=3306
MYSQL_DB=exhibition_db
MYSQL_ROOT_PASSWORD=root

# ===================== Redis =====================
REDIS_PORT=6379
REDIS_PASSWORD=redis123456

# ===================== MinIO =====================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio123456
MINIO_BUCKET=exhibition

# ===================== 后端 =====================
BACKEND_PORT=8080
# 人脸识别相似度阈值（0~1，越大越严）
FACE_THRESHOLD=0.82
# 日志级别：trace / debug / info / warn / error
LOG_LEVEL=info

# ===================== Nginx =====================
NGINX_PORT=80
