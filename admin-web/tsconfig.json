{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "types": ["node", "element-plus/global"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*", "src/**/*.vue"]
}
